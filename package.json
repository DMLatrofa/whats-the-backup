{
  "name": "whats-the-backup",
  "private": true,
  "version": "0.1.0",
  "description": "Desktop-first local viewer for WhatsApp exports.",
  "license": "MIT",
  "homepage": "https://github.com/DMLatrofa/whats-the-backup",
  "repository": {
    "type": "git",
    "url": "https://github.com/DMLatrofa/whats-the-backup.git"
  },
  "bugs": {
    "url": "https://github.com/DMLatrofa/whats-the-backup/issues"
  },
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "dev": "pnpm run dev:web",
    "dev:web": "pnpm --filter @wtb/desktop dev",
    "dev:desktop": "pnpm --filter @wtb/desktop tauri:dev",
    "build": "pnpm --filter @wtb/parser build && pnpm --filter @wtb/desktop build",
    "build:web": "pnpm run build",
    "build:desktop": "pnpm --filter @wtb/parser build && pnpm --filter @wtb/desktop tauri:build",
    "build:windows": "pnpm run build:desktop",
    "test": "pnpm --filter @wtb/parser test && pnpm --filter @wtb/desktop test",
    "test:all": "pnpm run test",
    "test:desktop": "pnpm --filter @wtb/desktop test",
    "test:parser": "pnpm --filter @wtb/parser test",
    "test:coverage": "pnpm --filter @wtb/parser test:coverage && pnpm --filter @wtb/desktop test:coverage",
    "lint": "pnpm --filter @wtb/parser lint && pnpm --filter @wtb/desktop lint"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4"
  }
}
